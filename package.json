{
  "name": "oc-nguyen-fullstack",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w apps/api\" \"npm run dev -w apps/web\"",
    "api:dev": "npm run start:dev -w apps/api",
    "web:dev": "npm run dev -w apps/web",
    "api:prisma": "npm run prisma:generate -w apps/api && npm run prisma:migrate -w apps/api && npm run db:seed -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "react-hot-toast": "^2.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
